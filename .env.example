# Razorpay — get keys from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=your_secret_key_here

# Server port
PORT=3001

# Optional CORS origin for production.
# If your frontend is hosted on a different domain, set it here.
# CORS_ORIGIN=https://your-frontend-domain.com

# Optional: API URL for production (leave empty to use same origin / proxy)
# VITE_API_URL=https://your-domain.com
